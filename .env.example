# Set MOCK_DB=true to run the app without a MongoDB connection
# (uses hardcoded mock data — useful for local UI development without a DB)
MOCK_DB=false

# MongoDB connection string (local or Atlas) — only used when MOCK_DB=false
MONGODB_URI=mongodb://127.0.0.1:27017/digischool

# JWT secret for authentication (change this in production!)
JWT_SECRET=your-jwt-secret-key-here

# Google Gemini API key (for AI features)
GEMINI_API_KEY=your-google-gemini-api-key-here

# Anthropic Claude API key (for AI features)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Chrome path for Puppeteer PDF generation
CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Redis URL (optional — falls back to in-memory cache)
REDIS_URL=redis://localhost:6379
